#!/bin/bash
# nvctgp <watt> — aktif platform_profile icin GPU Configurable-TGP tavanini ayarla.
#   tavan = 125W base + cTGP.  Gecerli: 125..175W (hard cap 175). Birim = 1/8 W.
#   EC tablosunda +0x57 (16-bit LE) alanina /dev/mem uzerinden pwrite ile yazar,
#   sonra \WS1D ile driver'a (nvidia-powerd) re-read dedirtir.
set -euo pipefail

BASE_W=130; MAX_W=175
w=${1:?kullanim: nvctgp <watt 125-175>}
(( w < BASE_W )) && w=$BASE_W
(( w > MAX_W ))  && w=$MAX_W
units=$(( (w - BASE_W) * 8 ))

[[ -e /proc/acpi/call ]] || modprobe acpi_call
call(){ echo "$1" > /proc/acpi/call; tr -d '\0' < /proc/acpi/call; }

base=$(call '\WS09'); b=$(( base ))
(( b == 0 )) && { echo "HATA: WS09 base=0 (tablo dolu degil)"; exit 1; }
addr=$(( b + 0x57 ))

# /dev/mem'e mmap yerine pread/pwrite (ACPI NVS mmap cakismasini asar)
python3 - "$addr" "$units" <<'PY'
import sys, os, struct
addr = int(sys.argv[1]); units = int(sys.argv[2]) & 0xFFFF
data = struct.pack('<H', units)                 # 16-bit little-endian
fd = os.open('/dev/mem', os.O_RDWR)
try:
    os.pwrite(fd, data, addr)                    # yaz
    back = os.pread(fd, 2, addr)                 # geri oku
finally:
    os.close(fd)
got = struct.unpack('<H', back)[0]
print(f"wrote={units} readback={got}")
sys.exit(0 if got == units else 2)
PY
rc=$?

call '\WS1D' >/dev/null

if (( rc == 0 )); then
  echo "OK: cTGP=${w}W (units=$units @ $(printf '0x%X' "$addr"))"
else
  echo "UYARI: readback tutmadi (rc=$rc)"; exit 2
fi
